{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --exec \"tsx src/index.ts\" --ext ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "migrate": "node-pg-migrate up",
    "migrate:create": "node-pg-migrate create",
    "migrate:down": "node-pg-migrate down",
    "migrate:prod": "node-pg-migrate up --envPath .env.production",
    "migrate:prod:down": "node-pg-migrate down --envPath .env.production",
    "format": "biome format --write ./src",
    "lint": "biome lint --apply ./src",
    "check": "biome check ./src",
    "check:fix": "biome check --write ./src",
    "loadtest": "tsx loadtest/broadcast-latency.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "fractional-indexing": "^3.2.0",
    "node-pg-migrate": "^8.0.4",
    "nodemon": "^3.1.14",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
